# Server
PORT=4000

# Comma-separated allowed CORS origins (leave empty to allow all — fine for mobile-only APIs)
# e.g. ALLOWED_ORIGINS=https://admin.karigar.app,https://karigar.app
ALLOWED_ORIGINS=

# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/karigar?appName=Cluster0

# JWT auth
JWT_SECRET=replace_with_a_long_random_hex_string
JWT_EXPIRY=30d

# Field-level encryption key (AES-256-GCM) — MUST be 32 bytes = 64 hex chars
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_characters

# Cloudinary (Aadhaar photo uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Instant-order dispatch: seconds a worker has to accept before auto-skip
OFFER_TTL_SECONDS=60

# Firebase Cloud Messaging (push notifications).
# Local dev: put the service-account JSON file in backend/ (auto-loaded).
# On Render/production: paste the ENTIRE service-account JSON as one line here:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
